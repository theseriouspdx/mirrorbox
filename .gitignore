# Dependency directories
node_modules/

# OS metadata
.DS_Store
Thumbs.db

# Python cache artifacts
__pycache__/
*.pyc

# Project state and logs
data/
logs/
*.log
mirrorbox.db*

# Environment and Secrets
.env
.env.*
!.env.sandbox

# Local MCP configs (machine-specific paths — see AGENTS.md Section 11 for setup)
.mcp.json
.gemini/

# Generated plist (from scripts/com.mbo.mcp.plist.template via mbo-launchd-install.sh)
scripts/com.mbo.mcp.plist

# DID artifacts
.dev/did/

# Root cleanup artifacts
.tmp-*.db

# Runtime session artifacts
.mbo/run/
.mbo/*.json
.journal/session.lock
.dev/run/write.deny
.dev/run/mcp-*.json
.dev/run/mcp.json

# Scratch files
scripts/scratch/
.journal/state.json

# MBO — per-user data (not committed)
.mbo/
!.mbo/onboarding.json
!.mbo/BUGS.md
!.mbo/CHANGELOG.md

!.mbo/AGENTS.md

# Stale local worktree snapshots (must never be tracked)
.dev/worktree/
.dev/worktree_archive/

# Scratch/tmp artifacts (never tracked)
.dev/tmp/
