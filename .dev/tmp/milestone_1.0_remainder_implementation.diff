## 1. New File: src/state/relay-listener.js (Mirror World)
```javascript
const net = require('net');
const fs = require('fs');
const eventStore = require('./event-store');
const db = require('./db-manager');

const SOCKET_PATH = '.dev/run/relay.sock';

/**
 * Section 24: The Relay Listener
 * Persistent UDS server in Mirror World.
 */
class RelayListener {
  constructor() {
    this.server = null;
    this.lastSeenSeq = 0;
    this.activeTask = null;
  }

  start(taskId) {
    this.activeTask = taskId;
    if (fs.existsSync(SOCKET_PATH)) {
      try { fs.unlinkSync(SOCKET_PATH); } catch (e) {}
    }
    
    this.server = net.createServer((socket) => {
      console.error(`[Relay] Subject connected.`);
      socket.on('data', (data) => this.handlePacket(socket, data));
      socket.on('end', () => console.error(`[Relay] Subject disconnected.`));
    });

    this.server.listen(SOCKET_PATH, () => {
      console.error(`[Relay] Listening on ${SOCKET_PATH}`);
    });
  }

  handlePacket(socket, data) {
    const lines = data.toString().split('\n');
    for (const line of lines) {
      if (!line.trim()) continue;
      try {
        const packet = JSON.parse(line);
        if (this.validate(packet)) {
          eventStore.append(packet.event, packet.actor, packet.payload, 'subject');
          this.lastSeenSeq = packet.seq;
        } else {
          this.violation(socket, packet, "Guard validation failed");
        }
      } catch (e) {
        this.violation(socket, null, `Malformed NDJSON: ${e.message}`);
      }
    }
  }

  /**
   * Section 25: The Guard
   */
  validate(packet) {
    if (packet.world_id !== 'subject') return false;
    if (packet.task_id !== this.activeTask) return false;
    if (packet.seq !== this.lastSeenSeq + 1) return false;
    
    // Path Scope & Governance Protection
    const payloadStr = JSON.stringify(packet.payload);
    if (payloadStr.includes('AGENTS.md') || payloadStr.includes('SPEC.md') || payloadStr.includes('.dev/governance/')) {
      return false;
    }

    return true;
  }

  violation(socket, packet, reason) {
    console.error(`[GUARD] Security Violation: ${reason}`);
    socket.destroy();
    fs.writeFileSync('.dev/run/incident.flag', JSON.stringify({ 
      reason, 
      packet, 
      ts: new Date().toISOString() 
    }));
  }

  stop() {
    if (this.server) {
      this.server.close();
      if (fs.existsSync(SOCKET_PATH)) fs.unlinkSync(SOCKET_PATH);
    }
  }
}

module.exports = new RelayListener();
```

## 2. New File: src/state/relay-emitter.js (Subject World)
```javascript
const net = require('net');
const SOCKET_PATH = '.dev/run/relay.sock';

/**
 * Section 24: The Relay Emitter
 * Embedded module in Subject runtime.
 */
class RelayEmitter {
  constructor(taskId) {
    this.taskId = taskId;
    this.seq = 1;
    this.client = net.createConnection(SOCKET_PATH);
    
    this.client.on('error', (err) => {
      console.error(`[Relay] Connection error: ${err.message}`);
      process.exit(1); // Section 24.6: RELAY_SEVERED halts Subject
    });
  }

  emit(event, actor, payload) {
    const packet = {
      event,
      actor,
      world_id: 'subject',
      task_id: this.taskId,
      seq: this.seq++,
      ts: new Date().toISOString(),
      payload
    };
    this.client.write(JSON.stringify(packet) + '\n');
  }

  close() {
    this.emit('RELAY_DISCONNECTED', 'subject-runner', {});
    this.client.end();
  }
}

module.exports = RelayEmitter;
```

## 3. New File: src/state/pile.js
```javascript
const { execSync } = require('child_process');
const fs = require('fs');
const path = require('path');
const eventStore = require('./event-store');

/**
 * Section 26: The Pile
 */
class Pile {
  promote(taskId, approvedFiles, mirrorRoot, subjectRoot) {
    const lockPath = '.dev/run/pile.lock';
    if (fs.existsSync(lockPath)) throw new Error("Pile already in progress.");
    fs.writeFileSync(lockPath, JSON.stringify({ taskId, ts: Date.now() }));

    try {
      console.error(`[Pile] Promoting ${approvedFiles.length} files to Subject...`);
      
      // Step 5: Subject Checkpoint (simplified rsync snapshot)
      const checkpointDir = path.join('.dev/snapshots', `subject_${Date.now()}`);
      fs.mkdirSync(checkpointDir, { recursive: true });
      execSync(`rsync -a --link-dest=${subjectRoot} ${subjectRoot}/ ${checkpointDir}/`);

      // Step 6: Promote via rsync
      for (const file of approvedFiles) {
        const src = path.join(mirrorRoot, file);
        const dest = path.join(subjectRoot, file);
        const destDir = path.dirname(dest);
        if (!fs.existsSync(destDir)) fs.mkdirSync(destDir, { recursive: true });
        
        execSync(`rsync -a --checksum ${src} ${dest}`);
      }

      eventStore.append('PILE_PROMOTED', 'mirror-operator', { files: approvedFiles, checkpoint: checkpointDir }, 'mirror');
      console.error(`[Pile] Promotion complete.`);
    } catch (e) {
      eventStore.append('PILE_FAILED', 'mirror-operator', { error: e.message }, 'mirror');
      throw e;
    } finally {
      if (fs.existsSync(lockPath)) fs.unlinkSync(lockPath);
    }
  }
}

module.exports = new Pile();
```

