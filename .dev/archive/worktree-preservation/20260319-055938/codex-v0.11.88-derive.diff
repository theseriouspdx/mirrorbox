+function renderBriefingForChat(briefing) {
+  const lines = [];
+
+  lines.push('Before questions, here is what I found from your project scan:');
+
+  if (Array.isArray(briefing.confirmed) && briefing.confirmed.length > 0) {
+    lines.push('Confirmed:');
+    for (const item of briefing.confirmed) lines.push(`- ${item}`);
+  }
+
+  if (Array.isArray(briefing.inferred) && briefing.inferred.length > 0) {
+    lines.push('Inferred (please confirm):');
+    for (const item of briefing.inferred) lines.push(`- ${item}`);
+  }
+
+  if (Array.isArray(briefing.unknown) && briefing.unknown.length > 0) {
+    lines.push('Unknown (I will ask):');
+    for (const item of briefing.unknown) lines.push(`- ${item}`);
+  }
+
+  return lines.join('\n');
+}
