+async function testCopiedProfileTriggersReonboardStatus() {
+  const sourceRoot = mktempProject();
+  const targetRoot = mktempProject();
+  const subjectRoot = fs.mkdtempSync(path.join(os.tmpdir(), 'mbo-subject-copy-'));
+
+  await runOnboarding(sourceRoot, null, {
+    nonInteractive: true,
+    answers: {
+      projectType: 'existing',
+      users: 'ops',
+      q3Raw: 'protect auth',
+      q4Raw: 'keep logs clear',
+    },
+    followup: {
+      subjectRoot,
+      verificationCommands: 'npm test',
+      dangerZones: 'lib/index.js',
+      realConstraints: 'auth stability',
+      assumedConstraints: 'legacy infra',
+    },
+  });
+
+  const copied = JSON.parse(fs.readFileSync(path.join(sourceRoot, '.mbo', 'onboarding.json'), 'utf8'));
+  delete copied.projectRoot;
+  fs.writeFileSync(path.join(targetRoot, '.mbo', 'onboarding.json'), JSON.stringify(copied, null, 2));
+
+  const status = await checkOnboarding(targetRoot, { autoRun: false, returnStatus: true });
+  assert(status.needsOnboarding === true, 'Copied profile should require re-onboarding');
+  eq(status.reason, 'profile_incomplete_or_stale', 'Copied profile re-onboard reason');
+}
+
